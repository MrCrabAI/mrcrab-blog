---
// Theme-aware Mr. Crab logo.
// Default: bare line-art crab in currentColor (matches surrounding text color).
// Under [data-theme="bili"] with `tile`: white strokes on a B站-pink rounded tile.
interface Props {
  size?: number;
  tile?: boolean;
  class?: string;
}
const { size = 32, tile = false, class: cls = '' } = Astro.props;
---

<span
  class:list={['crab-glyph', { 'crab-glyph--tile': tile }, cls]}
  style={`width:${size}px;height:${size}px`}
  aria-hidden="true"
>
  <svg viewBox="0 0 320 240" width="100%" height="100%">
    <g class="crab-glyph__ink" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
      <ellipse cx="160" cy="135" rx="52" ry="42"></ellipse>
      <line x1="140" y1="98" x2="128" y2="58"></line>
      <line x1="180" y1="98" x2="192" y2="58"></line>
      <circle cx="128" cy="55" r="4" fill="currentColor"></circle>
      <circle cx="192" cy="55" r="4" fill="currentColor"></circle>
      <polyline points="140,125 152,132 140,139"></polyline>
      <polyline points="180,125 168,132 180,139"></polyline>
      <path d="M 150 152 Q 160 158 170 152"></path>
      <path d="M 115 120 Q 92 108 75 90"></path>
      <path d="M 205 120 Q 228 108 245 90"></path>
      <line x1="135" y1="172" x2="128" y2="190"></line>
      <line x1="150" y1="176" x2="148" y2="194"></line>
      <line x1="170" y1="176" x2="172" y2="194"></line>
      <line x1="185" y1="172" x2="192" y2="190"></line>
    </g>
  </svg>
</span>

<style>
  .crab-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    flex: none;
  }
  .crab-glyph svg { display: block; width: 100%; height: 100%; }
  /* B站 skin: white crab on a pink rounded tile */
  :global([data-theme='bili']) .crab-glyph--tile {
    background: var(--accent);
    border-radius: 10px;
    padding: 5px;
    color: #fff;
  }
</style>
